@model TechMove.GLMS.Web.Models.Agreement

@{
    ViewData["Title"] = "Edit Agreement";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil-square"></i> Edit Agreement
            </div>
            <div class="card-body">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="AgreementId" />
                    <input type="hidden" asp-for="SignedAgreementPath" />

                    <div class="mb-3">
                        <label asp-for="ClientId" class="form-label">Client</label>
                        <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId"></select>
                        <span asp-validation-for="ClientId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<TechMove.GLMS.Web.Models.AgreementStatus>()"></select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ServiceLevel" class="form-label">Service Level</label>
                            <select asp-for="ServiceLevel" class="form-select" asp-items="Html.GetEnumSelectList<TechMove.GLMS.Web.Models.ServiceLevelType>()"></select>
                            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Terms" class="form-label">Terms & Conditions</label>
                        <textarea asp-for="Terms" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Terms" class="text-danger"></span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <div class="mb-3">
                            <label class="form-label">Current PDF</label>
                            <div>
                                <a asp-action="DownloadFile" asp-route-id="@Model.AgreementId" class="btn btn-sm btn-info">
                                    <i class="bi bi-download"></i> Download Current PDF
                                </a>
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label for="pdfFile" class="form-label">Replace PDF (optional)</label>
                        <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
                        <small class="text-muted">Leave empty to keep current file</small>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}