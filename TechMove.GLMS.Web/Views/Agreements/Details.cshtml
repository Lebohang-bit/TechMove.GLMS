@model TechMove.GLMS.Web.Models.Agreement

@{
    ViewData["Title"] = "Agreement Details";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-file-contract"></i> Agreement Details
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Client</dt>
                    <dd class="col-sm-9">@Model.Client?.Name</dd>

                    <dt class="col-sm-3">Start Date</dt>
                    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

                    <dt class="col-sm-3">End Date</dt>
                    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        @if (Model.Status == AgreementStatus.Active)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else if (Model.Status == AgreementStatus.Draft)
                        {
                            <span class="badge bg-secondary">Draft</span>
                        }
                        else if (Model.Status == AgreementStatus.Expired)
                        {
                            <span class="badge bg-danger">Expired</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">On Hold</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Service Level</dt>
                    <dd class="col-sm-9">@Model.ServiceLevel</dd>

                    <dt class="col-sm-3">Terms</dt>
                    <dd class="col-sm-9">@Model.Terms</dd>

                    <dt class="col-sm-3">Signed Agreement</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                        {
                            <a asp-action="DownloadFile" asp-route-id="@Model.AgreementId" class="btn btn-info">
                                <i class="bi bi-download"></i> Download PDF
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No file uploaded</span>
                        }
                    </dd>
                </dl>

                <hr />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.AgreementId" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>