@model IEnumerable<TechMove.GLMS.Web.Models.Agreement>

@{
    ViewData["Title"] = "Agreements";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Agreements</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-file-earmark-plus"></i> New Agreement
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Client</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Service Level</th>
                <th>PDF</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Client.Name)</td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.EndDate.ToShortDateString()</td>
                    <td>
                        @if (item.Status == AgreementStatus.Active)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else if (item.Status == AgreementStatus.Draft)
                        {
                            <span class="badge bg-secondary">Draft</span>
                        }
                        else if (item.Status == AgreementStatus.Expired)
                        {
                            <span class="badge bg-danger">Expired</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">On Hold</span>
                        }
                    </td>
                    <td>@item.ServiceLevel</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                        {
                            <a asp-action="DownloadFile" asp-route-id="@item.AgreementId" class="btn btn-sm btn-info">
                                <i class="bi bi-download"></i> PDF
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No file</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.AgreementId" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.AgreementId" class="btn btn-sm btn-info">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.AgreementId" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>