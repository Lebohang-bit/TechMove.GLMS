@model TechMove.GLMS.Web.Models.Agreement

@{
    ViewData["Title"] = "Delete Agreement";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-trash"></i> Delete Agreement
            </div>
            <div class="card-body">
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> Are you sure you want to delete this agreement?
                    <br />
                    <small>This will also delete any uploaded PDF file.</small>
                </div>

                <dl class="row">
                    <dt class="col-sm-3">Client</dt>
                    <dd class="col-sm-9">@Model.Client?.Name</dd>

                    <dt class="col-sm-3">Start Date</dt>
                    <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

                    <dt class="col-sm-3">End Date</dt>
                    <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@Model.Status</dd>

                    <dt class="col-sm-3">Service Level</dt>
                    <dd class="col-sm-9">@Model.ServiceLevel</dd>
                </dl>

                <hr />
                <form asp-action="Delete">
                    <input type="hidden" asp-for="AgreementId" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Confirm Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>